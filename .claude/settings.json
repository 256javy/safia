{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm start:*)",
      "Bash(pnpm generate-manifest:*)",
      "Bash(pnpm generate-manifest)",
      "Bash(pnpm test:*)",
      "Bash(npx tsx:*)",
      "Bash(tsx:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(node:*)"
    ],
    "deny": [
      "Edit(//home/javy/projects/safia/.env.local)",
      "Write(//home/javy/projects/safia/.env.local)",
      "Edit(//home/javy/projects/protonpass-training/**)",
      "Write(//home/javy/projects/protonpass-training/**)",
      "Edit(//home/javy/workspace/**)",
      "Write(//home/javy/workspace/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard-simulator.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard-service-key.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/auto-manifest.py",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/sprint-context.py",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
